{
  "meta": {
    "version": "0.3.0",
    "law_id": "340AC0000000033",
    "law_name": "所得税法"
  },
  "indexes": [
    {
      "rule_id": "IDX-074-001",
      "law_text_ref": {
        "article_id": "LAW-074-000",
        "content_hash": "sha256:（実際の運用時はAPIレスポンスから計算）",
        "article_num": "第七十四条",
        "paragraph": 1
      },
      "category": "所得控除",
      "sub_category": "社会保険料控除",
      "description": "居住者が社会保険料を支払った場合、支払った全額を所得から控除できる規定。",
      "calculation": {
        "type": "fixed_amount_deduction",
        "formula": {
          "expression": "控除額 = 支払社会保険料の合計額",
          "description": "その年に実際に支払った社会保険料の全額を控除する。",
          "variables": {
            "社会保険料": {
              "name": "社会保険料",
              "description": "第74条第2項各号に掲げる社会保険料の年間支払合計額",
              "amount": "user_input",
              "source": "user_input",
              "legal_basis": "第74条第1項"
            }
          },
          "summary_table": {
            "headers": [
              "対象",
              "控除額"
            ],
            "rows": [
              [
                "支払社会保険料",
                "支払額の全額"
              ]
            ]
          },
          "step_by_step": [
            {
              "step": 1,
              "description": "年間の社会保険料支払額を集計します",
              "expression": "健康保険、国民年金、厚生年金等の保険料を合計",
              "note": "給与控除分を含む。第74条第2項の限定列挙"
            },
            {
              "step": 2,
              "description": "合計額をそのまま控除します",
              "expression": "控除額 = 支払社会保険料の合計額"
            }
          ]
        },
        "effect": {
          "type": "reduces_taxable_income",
          "description": "計算された控除額が総所得金額、退職所得金額、山林所得金額から控除される"
        }
      },
      "test_cases": [
        {
          "description": "社会保険料30万円支払",
          "input": {
            "社会保険料": 300000
          },
          "expected_output": 300000,
          "calculation": "控除額 30万円"
        },
        {
          "description": "社会保険料0円",
          "input": {
            "社会保険料": 0
          },
          "expected_output": 0,
          "calculation": "控除額 0円"
        }
      ],
      "relation_to_other_rules": [
        {
          "related_rule_id": "IDX-074-002",
          "relation": "第74条第2項で社会保険料の範囲が定義されている"
        }
      ]
    }
  ]
}