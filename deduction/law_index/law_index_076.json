{
  "meta": {
    "version": "0.3.0",
    "law_id": "340AC0000000033",
    "law_name": "所得税法"
  },
  "indexes": [
    {
      "rule_id": "IDX-076-001",
      "law_text_ref": {
        "article_id": "LAW-076-000",
        "content_hash": "sha256:（実際の運用時はAPIレスポンスから計算）",
        "article_num": "第七十六条",
        "paragraph": 1
      },
      "category": "所得控除",
      "sub_category": "生命保険料控除",
      "description": "居住者が生命保険料等を支払った場合に、支払額に応じた段階的な控除を受けられる規定。新契約・旧契約、生命保険・介護医療保険・個人年金保険の各区分で計算し、合計上限12万円。",
      "calculation": {
        "type": "tiered_cap_deduction",
        "formula": {
          "expression": "控除額 = min(新生命 + 旧生命(上限4万併用時) + 介護医療 + 新年金 + 旧年金(上限4万併用時), 12万円) ※旧契約単独は上限5万円",
          "description": "5区分それぞれで段階計算（上限4万円/区分）、合計上限12万円。",
          "variables": {
            "新生命保険料": {
              "name": "新生命保険料",
              "description": "平成24年1月1日以後締結の生命保険契約等に係る保険料（剰余金等控除後）",
              "source": "user_input",
              "unit": "JPY"
            },
            "旧生命保険料": {
              "name": "旧生命保険料",
              "description": "平成23年12月31日以前締結の生命保険契約等に係る保険料",
              "source": "user_input",
              "unit": "JPY"
            },
            "介護医療保険料": {
              "name": "介護医療保険料",
              "description": "介護医療保険契約等に係る保険料",
              "source": "user_input",
              "unit": "JPY"
            },
            "新個人年金保険料": {
              "name": "新個人年金保険料",
              "description": "平成24年1月1日以後締結の個人年金保険契約等に係る保険料",
              "source": "user_input",
              "unit": "JPY"
            },
            "旧個人年金保険料": {
              "name": "旧個人年金保険料",
              "description": "平成23年12月31日以前締結の個人年金保険契約等に係る保険料",
              "source": "user_input",
              "unit": "JPY"
            }
          },
          "tier_formula": {
            "description": "各カテゴリ共通の段階計算式（新契約用）",
            "brackets": [
              {
                "range": "2万円以下",
                "formula": "保険料の全額"
              },
              {
                "range": "2万円超4万円以下",
                "formula": "2万円 + (保険料 - 2万円) × 1/2"
              },
              {
                "range": "4万円超8万円以下",
                "formula": "3万円 + (保険料 - 4万円) × 1/4"
              },
              {
                "range": "8万円超",
                "formula": "4万円"
              }
            ]
          },
          "tier_formula_old": {
            "description": "旧契約用の段階計算式（新契約より緩やか）",
            "brackets": [
              {
                "range": "2.5万円以下",
                "formula": "保険料の全額"
              },
              {
                "range": "2.5万円超5万円以下",
                "formula": "2.5万円 + (保険料 - 2.5万円) × 1/2"
              },
              {
                "range": "5万円超10万円以下",
                "formula": "3.75万円 + (保険料 - 5万円) × 1/4"
              },
              {
                "range": "10万円超",
                "formula": "5万円"
              }
            ]
          },
          "step_by_step": [
            {
              "step": 1,
              "description": "新生命保険料の控除額を計算",
              "expression": "新生命保険料にtier_formulaを適用。旧生命保険料と併用の場合は合計上限4万円",
              "note": "第76条第1項第1号・第3号"
            },
            {
              "step": 2,
              "description": "介護医療保険料の控除額を計算",
              "expression": "介護医療保険料にtier_formulaを適用（上限4万円）",
              "note": "第76条第2項"
            },
            {
              "step": 3,
              "description": "新個人年金保険料の控除額を計算",
              "expression": "新個人年金保険料にtier_formulaを適用。旧個人年金保険料と併用の場合は合計上限4万円",
              "note": "第76条第3項"
            },
            {
              "step": 4,
              "description": "旧生命保険料の控除額を計算",
              "expression": "旧生命保険料にtier_formula_oldを適用",
              "note": "第76条第1項第2号"
            },
            {
              "step": 5,
              "description": "旧個人年金保険料の控除額を計算",
              "expression": "旧個人年金保険料にtier_formula_oldを適用",
              "note": "第76条第3項第2号"
            },
            {
              "step": 6,
              "description": "合計し全体上限12万円を適用",
              "expression": "控除額 = min(5区分の合計, 12万円)",
              "note": "第76条第4項"
            }
          ],
          "summary_table": {
            "headers": [
              "区分",
              "計算式",
              "上限"
            ],
            "rows": [
              [
                "新生命保険料",
                "段階式（2万/4万/8万）",
                "4万円"
              ],
              [
                "旧生命保険料",
                "段階式（2.5万/5万/10万）",
                "5万円"
              ],
              [
                "新＋旧生命保険料併用",
                "それぞれ計算→合算",
                "4万円"
              ],
              [
                "介護医療保険料",
                "段階式（2万/4万/8万）",
                "4万円"
              ],
              [
                "新個人年金保険料",
                "段階式（2万/4万/8万）",
                "4万円"
              ],
              [
                "旧個人年金保険料",
                "段階式（2.5万/5万/10万）",
                "5万円"
              ],
              [
                "新＋旧個人年金併用",
                "それぞれ計算→合算",
                "4万円"
              ],
              [
                "全体合計",
                "全区分の合計",
                "12万円"
              ]
            ]
          },
          "sub_calculations": {
            "new_contract": {
              "description": "新契約（平成24年1月1日以後締結）の計算",
              "tiers": [
                {
                  "range": "2万円以下",
                  "formula": "全額"
                },
                {
                  "range": "2万円超4万円以下",
                  "formula": "2万円 + (保険料-2万円)×1/2"
                },
                {
                  "range": "4万円超8万円以下",
                  "formula": "3万円 + (保険料-4万円)×1/4"
                },
                {
                  "range": "8万円超",
                  "formula": "4万円（上限）"
                }
              ],
              "limit": 40000
            },
            "old_contract": {
              "description": "旧契約（平成23年12月31日以前締結）の計算",
              "tiers": [
                {
                  "range": "2.5万円以下",
                  "formula": "全額"
                },
                {
                  "range": "2.5万円超5万円以下",
                  "formula": "2.5万円 + (保険料-2.5万円)×1/2"
                },
                {
                  "range": "5万円超10万円以下",
                  "formula": "3.75万円 + (保険料-5万円)×1/4"
                },
                {
                  "range": "10万円超",
                  "formula": "5万円（上限）"
                }
              ],
              "limit": 50000
            },
            "combined_limit": {
              "description": "新旧併用時の合算上限",
              "new_old_combined": 40000,
              "total_cap": 120000
            }
          }
        },
        "effect": {
          "type": "reduces_taxable_income",
          "description": "計算された控除額が総所得金額、退職所得金額、山林所得金額から控除される"
        }
      },
      "test_cases": [
        {
          "description": "新生命保険料6万円（単独）",
          "input": {
            "新生命保険料": 60000,
            "旧生命保険料": 0,
            "介護医療保険料": 0,
            "新個人年金保険料": 0,
            "旧個人年金保険料": 0
          },
          "expected_output": 35000,
          "calculation": "3万 + (6万-4万)×1/4 = 3.5万"
        },
        {
          "description": "新生命保険料6万円＋介護医療保険料3万円",
          "input": {
            "新生命保険料": 60000,
            "旧生命保険料": 0,
            "介護医療保険料": 30000,
            "新個人年金保険料": 0,
            "旧個人年金保険料": 0
          },
          "expected_output": 60000,
          "calculation": "生命3.5万 + 介護2.5万 = 6万"
        },
        {
          "description": "全区分上限張付き（12万円キャップ）",
          "input": {
            "新生命保険料": 100000,
            "旧生命保険料": 120000,
            "介護医療保険料": 100000,
            "新個人年金保険料": 100000,
            "旧個人年金保険料": 120000
          },
          "expected_output": 120000,
          "calculation": "各区分最大まで達するが合計12万円キャップ"
        },
        {
          "description": "すべて0円",
          "input": {
            "新生命保険料": 0,
            "旧生命保険料": 0,
            "介護医療保険料": 0,
            "新個人年金保険料": 0,
            "旧個人年金保険料": 0
          },
          "expected_output": 0,
          "calculation": "控除額0円"
        }
      ],
      "relation_to_other_rules": [
        {
          "related_rule_id": "IDX-076-005",
          "relation": "第76条第5〜9項で各契約の定義が詳細に規定されている"
        }
      ]
    }
  ]
}