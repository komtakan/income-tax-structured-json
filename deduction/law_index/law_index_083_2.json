{
  "meta": {
    "version": "0.3.0",
    "law_id": "340AC0000000033",
    "law_name": "所得税法"
  },
  "indexes": [
    {
      "rule_id": "IDX-083_2-001",
      "law_text_ref": {
        "article_id": "LAW-083_2-000",
        "content_hash": "sha256:（実際の運用時はAPIレスポンスから計算）",
        "article_num": "第八十三条の二",
        "paragraph": 1
      },
      "category": "所得控除",
      "sub_category": "配偶者特別控除",
      "description": "居住者に控除対象配偶者に該当しない配偶者（合計所得金額133万円以下）がいる場合に、居住者本人の所得と配偶者の所得に応じて控除額が定められる規定。控除額は配偶者の所得が増えるほど逓減する。",
      "calculation": {
        "type": "cap_deduction",
        "formula": {
          "expression": "控除額 = f(本人合計所得金額, 配偶者合計所得金額)",
          "description": "本人所得3段階×配偶者所得5区分のマトリックスで控除額が決定。配偶者所得95万円超で逓減開始、133万円超で適用外。",
          "variables": {
            "本人合計所得金額": {
              "name": "本人の合計所得金額",
              "description": "居住者本人の合計所得金額",
              "source": "calculated_from_user_profile",
              "unit": "JPY",
              "max_threshold": 10000000
            },
            "配偶者合計所得金額": {
              "name": "配偶者の合計所得金額",
              "description": "生計を一にする配偶者の合計所得金額",
              "source": "user_input",
              "unit": "JPY",
              "max_threshold": 1330000
            }
          },
          "brackets": [
            {
              "range": "本人900万円以下",
              "condition": "本人合計所得金額 <= 9000000",
              "sub_brackets": [
                {
                  "range": "配偶者95万円以下",
                  "condition": "配偶者合計所得金額 <= 950000",
                  "deduction": 380000
                },
                {
                  "range": "配偶者95万円超～100万円以下",
                  "condition": "950000 < 配偶者合計所得金額 <= 1000000",
                  "deduction": 360000
                },
                {
                  "range": "配偶者100万円超～105万円以下",
                  "condition": "1000000 < 配偶者合計所得金額 <= 1050000",
                  "deduction": 310000
                },
                {
                  "range": "配偶者105万円超～110万円以下",
                  "condition": "1050000 < 配偶者合計所得金額 <= 1100000",
                  "deduction": 260000
                },
                {
                  "range": "配偶者110万円超～115万円以下",
                  "condition": "1100000 < 配偶者合計所得金額 <= 1150000",
                  "deduction": 210000
                },
                {
                  "range": "配偶者115万円超～120万円以下",
                  "condition": "1150000 < 配偶者合計所得金額 <= 1200000",
                  "deduction": 160000
                },
                {
                  "range": "配偶者120万円超～125万円以下",
                  "condition": "1200000 < 配偶者合計所得金額 <= 1250000",
                  "deduction": 110000
                },
                {
                  "range": "配偶者125万円超～130万円以下",
                  "condition": "1250000 < 配偶者合計所得金額 <= 1300000",
                  "deduction": 60000
                },
                {
                  "range": "配偶者130万円超～133万円以下",
                  "condition": "1300000 < 配偶者合計所得金額 <= 1330000",
                  "deduction": 30000
                }
              ],
              "legal_basis": "第83条の2第1項第1号"
            },
            {
              "range": "本人900万円超～950万円以下",
              "condition": "9000000 < 本人合計所得金額 <= 9500000",
              "deduction_formula": "第1号の控除額 × 2/3（端数切上）",
              "legal_basis": "第83条の2第1項第2号"
            },
            {
              "range": "本人950万円超～1,000万円以下",
              "condition": "9500000 < 本人合計所得金額 <= 10000000",
              "deduction_formula": "第1号の控除額 × 1/3（端数切上）",
              "legal_basis": "第83条の2第1項第3号"
            },
            {
              "range": "本人1,000万円超",
              "condition": "本人合計所得金額 > 10000000",
              "deduction": 0,
              "description": "配偶者特別控除の適用なし"
            }
          ],
          "summary_table": {
            "headers": [
              "配偶者の合計所得金額",
              "本人900万円以下",
              "本人900万円超950万円以下",
              "本人950万円超1,000万円以下"
            ],
            "rows": [
              [
                "95万円以下",
                "38万円",
                "26万円",
                "13万円"
              ],
              [
                "95万円超～100万円以下",
                "36万円",
                "24万円",
                "12万円"
              ],
              [
                "100万円超～105万円以下",
                "31万円",
                "21万円",
                "11万円"
              ],
              [
                "105万円超～110万円以下",
                "26万円",
                "18万円",
                "9万円"
              ],
              [
                "110万円超～115万円以下",
                "21万円",
                "14万円",
                "7万円"
              ],
              [
                "115万円超～120万円以下",
                "16万円",
                "11万円",
                "6万円"
              ],
              [
                "120万円超～125万円以下",
                "11万円",
                "8万円",
                "4万円"
              ],
              [
                "125万円超～130万円以下",
                "6万円",
                "4万円",
                "2万円"
              ],
              [
                "130万円超～133万円以下",
                "3万円",
                "2万円",
                "1万円"
              ],
              [
                "133万円超",
                "0円",
                "0円",
                "0円"
              ]
            ]
          },
          "step_by_step": [
            {
              "step": 1,
              "description": "本人の合計所得金額が1,000万円以下か確認",
              "expression": "本人合計所得金額 <= 1,000万円 → 次ステップへ",
              "note": "1,000万円超は適用なし"
            },
            {
              "step": 2,
              "description": "配偶者の所得が48万円超133万円以下か確認",
              "expression": "48万円 < 配偶者合計所得金額 <= 133万円",
              "note": "48万円以下は控除対象配偶者（第83条）、133万円超は対象外"
            },
            {
              "step": 3,
              "description": "本人所得区分に応じた倍率を決定",
              "expression": "900万以下→1倍、900万超950万以下→2/3倍、950万超1,000万以下→1/3倍"
            },
            {
              "step": 4,
              "description": "配偶者所得区分に応じた控除額を決定し、倍率を乗じる",
              "expression": "基本控除額 × 倍率（端数切上）"
            }
          ]
        },
        "effect": {
          "type": "reduces_taxable_income",
          "description": "計算された控除額が総所得金額、退職所得金額、山林所得金額から控除される"
        }
      },
      "test_cases": [
        {
          "description": "本人所得400万・配偶者所得60万",
          "input": {
            "本人合計所得金額": 4000000,
            "配偶者合計所得金額": 600000
          },
          "expected_output": 380000,
          "calculation": "本人900万以下×配偶者95万以下 → 38万円"
        },
        {
          "description": "本人所得400万・配偶者所得110万",
          "input": {
            "本人合計所得金額": 4000000,
            "配偶者合計所得金額": 1100000
          },
          "expected_output": 260000,
          "calculation": "本人900万以下×配偶者105超110以下 → 26万円"
        },
        {
          "description": "本人所得920万・配偶者所得80万",
          "input": {
            "本人合計所得金額": 9200000,
            "配偶者合計所得金額": 800000
          },
          "expected_output": 260000,
          "calculation": "本人区分(二)×配偶者区分(一)→26万円（第83条の2第1項第2号の表）"
        },
        {
          "description": "本人所得980万・配偶者所得132万",
          "input": {
            "本人合計所得金額": 9800000,
            "配偶者合計所得金額": 1320000
          },
          "expected_output": 10000,
          "calculation": "本人950超1,000以下 → 3万×1/3=1万"
        },
        {
          "description": "本人所得1,200万（対象外）",
          "input": {
            "本人合計所得金額": 12000000,
            "配偶者合計所得金額": 800000
          },
          "expected_output": 0,
          "calculation": "1,000万円超 → 控除なし"
        }
      ],
      "relation_to_other_rules": [
        {
          "related_rule_id": "IDX-083-001",
          "relation": "第83条（配偶者控除）の対象から外れた配偶者が対象。両者の併用不可"
        },
        {
          "related_rule_id": "IDX-002-030-001",
          "relation": "第2条で「合計所得金額」が定義されている"
        }
      ]
    }
  ]
}