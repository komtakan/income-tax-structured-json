{
  "meta": {
    "version": "0.3.0",
    "law_id": "340AC0000000033",
    "law_name": "所得税法"
  },
  "indexes": [
    {
      "rule_id": "IDX-084_2-001",
      "law_text_ref": {
        "article_id": "LAW-084_2-000",
        "content_hash": "sha256:（実際の運用時はAPIレスポンスから計算）",
        "article_num": "第八十四条の二",
        "paragraph": 1
      },
      "category": "所得控除",
      "sub_category": "特定親族特別控除",
      "description": "居住者に年齢19歳以上23歳未満の親族（特定親族）で控除対象扶養親族に該当しない者がいる場合に、特定親族の合計所得金額に応じて控除額が逓減する規定。",
      "calculation": {
        "type": "cap_deduction",
        "formula": {
          "expression": "控除額 = Σ f(特定親族の合計所得金額)",
          "description": "特定親族ごとに、その合計所得金額に応じた控除額を合計する。",
          "variables": {
            "特定親族の合計所得金額": {
              "name": "特定親族の合計所得金額",
              "description": "特定親族（19〜22歳）の合計所得金額。123万円以下が対象。",
              "source": "user_input",
              "unit": "JPY",
              "max_threshold": 1230000
            }
          },
          "brackets": [
            {
              "range": "85万円以下",
              "condition": "特定親族の合計所得金額 <= 850000",
              "deduction": 630000,
              "legal_basis": "第84条の2第1項第1号"
            },
            {
              "range": "85万円超～115万円以下",
              "condition": "850000 < 特定親族の合計所得金額 <= 1150000",
              "deduction_formula": "63万円 - (特定親族の合計所得金額 - 84万1円) × 2（10万円単位で逓減）",
              "deduction_range": [
                630000,
                580000,
                480000,
                380000,
                280000,
                180000,
                80000
              ],
              "legal_basis": "第84条の2第1項第2号"
            },
            {
              "range": "115万円超～120万円以下",
              "condition": "1150000 < 特定親族の合計所得金額 <= 1200000",
              "deduction": 60000,
              "legal_basis": "第84条の2第1項第3号"
            },
            {
              "range": "120万円超～123万円以下",
              "condition": "1200000 < 特定親族の合計所得金額 <= 1230000",
              "deduction": 30000,
              "legal_basis": "第84条の2第1項第4号"
            },
            {
              "range": "123万円超",
              "condition": "特定親族の合計所得金額 > 1230000",
              "deduction": 0,
              "description": "特定親族特別控除の適用なし"
            }
          ],
          "summary_table": {
            "headers": [
              "特定親族の合計所得金額",
              "控除額（1人あたり）"
            ],
            "rows": [
              [
                "85万円以下",
                "63万円"
              ],
              [
                "85万円超～115万円以下",
                "63万円から段階逓減（最低8万円）"
              ],
              [
                "115万円超～120万円以下",
                "6万円"
              ],
              [
                "120万円超～123万円以下",
                "3万円"
              ],
              [
                "123万円超",
                "0円"
              ]
            ]
          },
          "step_by_step": [
            {
              "step": 0,
              "description": "適用除外の確認（二重適用禁止）",
              "expression": "特定親族が居住者本人として本条の適用を受けていない && 他者の源泉控除対象親族として申告されていない && 政令で定める場合に該当しない",
              "note": "第84条の2第2項各号。本人側での適用、他者扶養との重複を禁止"
            },
            {
              "step": 1,
              "description": "特定親族の該当可否を判定します",
              "expression": "年齢19歳以上23歳未満、生計一、合計所得金額123万円以下、控除対象扶養親族でないこと",
              "note": "第84条の2第1項本文"
            },
            {
              "step": 2,
              "description": "特定親族の合計所得金額を確認します",
              "expression": "特定親族の合計所得金額 = 総所得金額 + 退職所得金額 + 山林所得金額"
            },
            {
              "step": 3,
              "description": "所得区分に応じて控除額を決定します",
              "expression": "上記brackets表に従い控除額を決定"
            }
          ]
        },
        "effect": {
          "type": "reduces_taxable_income",
          "description": "計算された控除額が総所得金額、退職所得金額、山林所得金額から控除される"
        }
      },
      "test_cases": [
        {
          "description": "特定親族の所得80万円",
          "input": {
            "特定親族の合計所得金額": 800000
          },
          "expected_output": 630000,
          "calculation": "85万円以下 → 63万円"
        },
        {
          "description": "特定親族の所得95万円",
          "input": {
            "特定親族の合計所得金額": 950000
          },
          "expected_output": 580000,
          "calculation": "85万超115万以下 → 逓減後58万円"
        },
        {
          "description": "特定親族の所得118万円",
          "input": {
            "特定親族の合計所得金額": 1180000
          },
          "expected_output": 60000,
          "calculation": "115万超120万以下 → 6万円"
        },
        {
          "description": "特定親族の所得122万円",
          "input": {
            "特定親族の合計所得金額": 1220000
          },
          "expected_output": 30000,
          "calculation": "120万超123万以下 → 3万円"
        },
        {
          "description": "特定親族の所得130万円（対象外）",
          "input": {
            "特定親族の合計所得金額": 1300000
          },
          "expected_output": 0,
          "calculation": "123万円超 → 控除なし"
        }
      ],
      "relation_to_other_rules": [
        {
          "related_rule_id": "IDX-084-001",
          "relation": "第84条（扶養控除）の対象から外れた19〜22歳の親族が対象。両者の併用不可"
        },
        {
          "related_rule_id": "IDX-002-030-001",
          "relation": "第2条で「合計所得金額」が定義されている"
        }
      ]
    }
  ]
}