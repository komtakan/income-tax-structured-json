    "law_name": "所得税法"
  },
  "indexes": [
    {
      "rule_id": "IDX-086-001",
      "law_text_ref": {
        "article_id": "LAW-086-000",
        "content_hash": "sha256:（実際の運用時はAPIレスポンスから計算）",
        "article_num": "第八十六条",
        "paragraph": 1
      },
      "category": "所得控除",
      "sub_category": "基礎控除",
      "description": "すべての居住者に適用される基礎的な所得控除。合計所得金額に応じて控除額が段階的に減少する仕組み。合計所得金額が2,500万円を超えると控除額ゼロ。",
      "calculation": {
        "type": "cap_deduction",
        "formula": {
          "expression": "控除額 = f(合計所得金額)",
          "description": "合計所得金額に応じて4段階の控除額が定められている。2,500万円超は控除なし。",
          "variables": {
            "合計所得金額": {
              "name": "合計所得金額",
              "description": "第2条第1項第30号で定義。総所得金額＋退職所得金額＋山林所得金額の合計額（純損失・雑損失の繰越控除適用前）",
              "source": "calculated_from_user_profile",
              "unit": "JPY",
              "max_threshold": 25000000
            }
          },
          "brackets": [
            {
              "range": "〜23,500,000円以下",
              "condition": "合計所得金額 <= 23500000",
              "deduction": 580000,
              "legal_basis": "第86条第1項第1号"
            },
            {
              "range": "23,500,001円 〜 24,000,000円",
              "condition": "23500000 < 合計所得金額 <= 24000000",
              "deduction": 480000,
              "legal_basis": "第86条第1項第2号"
            },
            {
              "range": "24,000,001円 〜 24,500,000円",
              "condition": "24000000 < 合計所得金額 <= 24500000",
              "deduction": 320000,
              "legal_basis": "第86条第1項第3号"
            },
            {
              "range": "24,500,001円 〜 25,000,000円",
              "condition": "24500000 < 合計所得金額 <= 25000000",
              "deduction": 160000,
              "legal_basis": "第86条第1項第4号"
            },
            {
              "range": "25,000,001円超",
              "condition": "合計所得金額 > 25000000",
              "deduction": 0,
              "description": "基礎控除の適用なし"
            }
          ],
          "summary_table": {
            "headers": ["合計所得金額", "基礎控除額", "該当号"],
            "rows": [
              ["2,350万円以下", "58万円", "第1号"],
              ["2,350万円超〜2,400万円以下", "48万円", "第2号"],
              ["2,400万円超〜2,450万円以下", "32万円", "第3号"],
              ["2,450万円超〜2,500万円以下", "16万円", "第4号"],
              ["2,500万円超", "0円", "対象外"]
            ]
          },
          "step_by_step": [
            {
              "step": 1,
              "description": "合計所得金額を確認します",
              "expression": "合計所得金額 = 総所得金額 + 退職所得金額 + 山林所得金額",
              "note": "純損失・雑損失の繰越控除前の金額を使用"
            },
            {
              "step": 2,
              "description": "合計所得金額が2,500万円超の場合は基礎控除なし",
              "expression": "合計所得金額 > 25,000,000 → 控除額 = 0",
              "note": "2,500万円以下の場合のみ次のステップへ"
            },
            {
              "step": 3,
              "description": "所得区分に応じて控除額を決定します",
              "expression": "上記のbrackets表に従い控除額を決定",
              "note": "控除額は48万円（令和8年分は58万円に引き上げ済）"
            }
          ]
        },
        "effect": {
          "type": "reduces_taxable_income",
          "description": "計算された控除額が総所得金額、退職所得金額、山林所得金額から控除される。すべての居住者に適用されるが、高所得者（2,500万円超）は対象外。"
        }
      },
      "test_cases": [
        {
          "description": "典型的な給与所得者（合計所得400万円）",
          "input": { "合計所得金額": 4000000 },
          "expected_output": 580000,
          "calculation": "2,350万円以下 → 58万円"
        },
        {
          "description": "合計所得2,400万円（第2号）",
          "input": { "合計所得金額": 24000000 },
          "expected_output": 480000,
          "calculation": "2,350万円超2,400万円以下 → 48万円"
        },
        {
          "description": "合計所得2,500万円（第4号・上限）",
          "input": { "合計所得金額": 25000000 },
          "expected_output": 160000,
          "calculation": "2,450万円超2,500万円以下 → 16万円"
        },
        {
          "description": "合計所得3,000万円（対象外）",
          "input": { "合計所得金額": 30000000 },
          "expected_output": 0,
          "calculation": "2,500万円超 → 基礎控除なし"
        },
        {
          "description": "合計所得2,350万円（第1号上限）",
          "input": { "合計所得金額": 23500000 },
          "expected_output": 580000,
          "calculation": "2,350万円以下 → 58万円（境界値：以下は第1号）"
        }
      ],
      "relation_to_other_rules": [
        {
          "related_rule_id": "IDX-002-030-001",
          "relation": "第2条第1項第30号で「合計所得金額」が定義されている"
        },
        {
          "related_rule_id": "IDX-087-001",
          "relation": "第87条で所得控除の順序が定められており、基礎控除は雑損控除・医療費控除等の後に適用される"
        }
      ]
    }
  ]
}