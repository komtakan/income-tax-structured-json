  "articles": [
    {
      "article_id": "LAW-074-000",
      "article_num": "第74条",
      "article_title": "（社会保険料控除）",
      "content_hash": "sha256:0669d03156a1ec93d177f3d2cd9f513e3704240895465504290f9d3724b052f1",
      "api_revision_id": "340AC0000000033_20260401_508AC0000000012",
      "effective_date": "2026-04-01",
      "raw_json": {
        "Article": {
          "ArticleCaption": "（社会保険料控除）",
          "ArticleTitle": "第七十四条",
          "Paragraph": [
            {
              "ParagraphNum": null,
              "Num": "1",
              "ParagraphSentence": {
                "Sentence": [
                  "居住者が、各年において、自己又は自己と生計を一にする配偶者その他の親族の負担すべき社会保険料を支払つた場合又は給与から控除される場合には、その支払つた金額又はその控除される金額を、その居住者のその年分の総所得金額、退職所得金額又は山林所得金額から控除する。"
                ]
              }
            },
            {
              "ParagraphNum": "２",
              "Num": "2",
              "ParagraphSentence": {
                "Sentence": [
                  "前項に規定する社会保険料とは、次に掲げるものその他これらに準ずるもので政令で定めるもの（第九条第一項第七号（在勤手当の非課税）に掲げる給与に係るものを除く。）をいう。"
                ]
              },
              "Item": [
                {
                  "ItemTitle": "一",
                  "ItemSentence": {
                    "Sentence": [
                      "健康保険法（大正十一年法律第七十号）の規定により被保険者として負担する健康保険の保険料"
                    ]
                  }
                },
                {
                  "ItemTitle": "二",
                  "ItemSentence": {
                    "Sentence": [
                      "国民健康保険法（昭和三十三年法律第百九十二号）の規定による国民健康保険の保険料又は地方税法の規定による国民健康保険税"
                    ]
                  }
                },
                {
                  "ItemTitle": "二の二",
                  "ItemSentence": {
                    "Sentence": [
                      "高齢者の医療の確保に関する法律（昭和五十七年法律第八十号）の規定による保険料"
                    ]
                  }
                },
                {
                  "ItemTitle": "三",
                  "ItemSentence": {
                    "Sentence": [
                      "介護保険法（平成九年法律第百二十三号）の規定による介護保険の保険料"
                    ]
                  }
                },
                {
                  "ItemTitle": "四",
                  "ItemSentence": {
                    "Sentence": [
                      "労働保険の保険料の徴収等に関する法律（昭和四十四年法律第八十四号）の規定により雇用保険の被保険者として負担する労働保険料"
                    ]
                  }
                },
                {
                  "ItemTitle": "五",
                  "ItemSentence": {
                    "Sentence": [
                      "国民年金法の規定により被保険者として負担する国民年金の保険料及び国民年金基金の加入員として負担する掛金"
                    ]
                  }
                },
                {
                  "ItemTitle": "六",
                  "ItemSentence": {
                    "Sentence": [
                      "独立行政法人農業者年金基金法の規定により被保険者として負担する農業者年金の保険料"
                    ]
                  }
                },
                {
                  "ItemTitle": "七",
                  "ItemSentence": {
                    "Sentence": [
                      "厚生年金保険法の規定により被保険者として負担する厚生年金保険の保険料"
                    ]
                  }
                },
                {
                  "ItemTitle": "八",
                  "ItemSentence": {
                    "Sentence": [
                      "船員保険法の規定により被保険者として負担する船員保険の保険料"
                    ]
                  }
                },
                {
                  "ItemTitle": "九",
                  "ItemSentence": {
                    "Sentence": [
                      "国家公務員共済組合法の規定による掛金"
                    ]
                  }
                },
                {
                  "ItemTitle": "十",
                  "ItemSentence": {
                    "Sentence": [
                      "地方公務員等共済組合法の規定による掛金（特別掛金を含む。）"
                    ]
                  }
                },
                {
                  "ItemTitle": "十一",
                  "ItemSentence": {
                    "Sentence": [
                      "私立学校教職員共済法の規定により加入者として負担する掛金"
                    ]
                  }
                },
                {
                  "ItemTitle": "十二",
                  "ItemSentence": {
                    "Sentence": [
                      "恩給法第五十九条（恩給納金）（他の法律において準用する場合を含む。）の規定による納金"
                    ]
                  }
                }
              ]
            },
            {
              "ParagraphNum": "３",
              "Num": "3",
              "ParagraphSentence": {
                "Sentence": [
                  "第一項の規定による控除は、社会保険料控除という。"
                ]
              }
            }
          ]
        }
      }
    }
  ]
}