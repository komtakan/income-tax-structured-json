  "articles": [
    {
      "article_id": "LAW-075-000",
      "article_num": "第75条",
      "article_title": "（小規模企業共済等掛金控除）",
      "content_hash": "sha256:1d1eab490ee0bb1805a029055bc3103ad8d12a0fecdfa7bf364fa04afe8c68f0",
      "api_revision_id": "340AC0000000033_20260401_508AC0000000012",
      "effective_date": "2026-04-01",
      "raw_json": {
        "Article": {
          "ArticleCaption": "（小規模企業共済等掛金控除）",
          "ArticleTitle": "第七十五条",
          "Paragraph": [
            {
              "ParagraphNum": null,
              "Num": "1",
              "ParagraphSentence": {
                "Sentence": [
                  "居住者が、各年において、小規模企業共済等掛金を支払つた場合には、その支払つた金額を、その者のその年分の総所得金額、退職所得金額又は山林所得金額から控除する。"
                ]
              }
            },
            {
              "ParagraphNum": "２",
              "Num": "2",
              "ParagraphSentence": {
                "Sentence": [
                  "前項に規定する小規模企業共済等掛金とは、次に掲げる掛金をいう。"
                ]
              },
              "Item": [
                {
                  "ItemTitle": "一",
                  "ItemSentence": {
                    "Sentence": [
                      "小規模企業共済法（昭和四十年法律第百二号）第二条第二項（定義）に規定する共済契約（政令で定めるものを除く。）に基づく掛金"
                    ]
                  }
                },
                {
                  "ItemTitle": "二",
                  "ItemSentence": {
                    "Sentence": [
                      "確定拠出年金法（平成十三年法律第八十八号）第三条第三項第七号の二（規約の承認）に規定する企業型年金加入者掛金又は同法第五十五条第二項第四号（規約の承認）に規定する個人型年金加入者掛金"
                    ]
                  }
                },
                {
                  "ItemTitle": "三",
                  "ItemSentence": {
                    "Sentence": [
                      "第九条第一項第三号ハ（年金等の非課税）に規定する政令で定める共済制度に係る契約に基づく掛金"
                    ]
                  }
                }
              ]
            },
            {
              "ParagraphNum": "３",
              "Num": "3",
              "ParagraphSentence": {
                "Sentence": [
                  "第一項の規定による控除は、小規模企業共済等掛金控除という。"
                ]
              }
            }
          ]
        }
      }
    }
  ]
}