        "Article": {
          "ArticleCaption": "（寡婦控除）",
          "ArticleTitle": "第八十条",
          "Paragraph": [
            {
              "ParagraphNum": null,
              "Num": "1",
              "ParagraphSentence": {
                "Sentence": [
                  "居住者が寡婦である場合には、その者のその年分の総所得金額、退職所得金額又は山林所得金額から二十七万円を控除する。"
                ]
              }
            },
            {
              "ParagraphNum": "２",
              "Num": "2",
              "ParagraphSentence": {
                "Sentence": [
                  "前項の規定による控除は、寡婦控除という。"
                ]
              }
            }
          ]
        }
      }
    }
  ]
