      "raw_json": {
        "Article": {
          "ArticleCaption": "（ひとり親控除）",
          "ArticleTitle": "第八十一条",
          "Paragraph": [
            {
              "ParagraphNum": null,
              "Num": "1",
              "ParagraphSentence": {
                "Sentence": [
                  "居住者がひとり親である場合には、その者のその年分の総所得金額、退職所得金額又は山林所得金額から三十五万円を控除する。"
                ]
              }
            },
            {
              "ParagraphNum": "２",
              "Num": "2",
              "ParagraphSentence": {
                "Sentence": [
                  "前項の規定による控除は、ひとり親控除という。"
                ]
              }
            }
          ]
        }
      }
    }
  ]
